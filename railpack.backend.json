{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["cd backend && npm ci"]
    },
    "build": {
      "commands": ["cd backend && npm run build"]
    }
  },
  "deploy": {
    "inputs": [
      "...",
      { "step": "build", "include": ["backend"] }
    ],
    "startCommand": "cd backend && node --import ./dist/src/monitoring/instrument.js dist/src"
  }
}
