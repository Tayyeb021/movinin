{
  "expo": {
    "jsEngine": "hermes",
    "name": "Movin' In",
    "version": "6.7.0",
    "slug": "movinin",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "backgroundColor": "#0D63C9",
      "image": "./assets/splash.png"
    },
    "android": {
      "versionCode": 670,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "icon": "./assets/icon.png",
      "package": "com.movinin"
    },
    "ios": {
      "buildNumber": "6.7.0",
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.movinin"
    },
    "plugins": [
      "expo-localization",
      "./plugins/usesCleartextTraffic",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D63C9",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "MERCHANT_IDENTIFIER",
          "enableGooglePay": true
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "tsconfigPaths": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "be290071-e80b-4b29-91a0-95698818c749"
      }
    },
    "owner": "mtayyedd"
  }
}
