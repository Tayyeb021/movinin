{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["cd frontend && npm ci"]
    },
    "build": {
      "commands": ["cd frontend && npm run build"]
    }
  },
  "deploy": {
    "inputs": [
      { "step": "build", "include": ["frontend/build"] }
    ]
  }
}
